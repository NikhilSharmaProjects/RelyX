# Required threat intelligence keys
GOOGLE_SAFE_BROWSING_API_KEY="YOUR_GOOGLE_SAFE_BROWSING_KEY"
VIRUSTOTAL_API_KEY="YOUR_VIRUSTOTAL_KEY"
PHISHTANK_API_KEY="YOUR_PHISHTANK_KEY"

# Optional WHOIS API (if absent, backend falls back to python-whois)
WHOIS_API_KEY="YOUR_WHOISXMLAPI_KEY"
WHOIS_API_URL="https://www.whoisxmlapi.com/whoisserver/WhoisService"

# Optional LLM explanation provider (LLM does not decide risk)
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"
OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"
OPENAI_MODEL="sarvamai/sarvam-m"

# Optional PhishTank endpoint override
PHISHTANK_CHECK_URL="https://checkurl.phishtank.com/checkurl/"
